    "postinstall": "wxt prepare",
    "clean": "rm -rf .output .wxt dist"
  },
  "dependencies": {
    "@byn/core": "workspace:*",
    "@byn/dom-scanner": "workspace:*",
    "@byn/ui-kit": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@wxt-dev/module-react": "1.1.2",
    "typescript": "^5.7.2",
    "wxt": "0.19.29"
  }
}
